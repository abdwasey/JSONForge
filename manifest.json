{
  "manifest_version": 3,
  "name": "JsonForge",
  "description": "Convert JSON into Java, TypeScript, Kotlin, C#, and other class/interface models instantly.",
  "version": "1.0.0",

  "action": {
    "default_popup": "popup.html",
    "default_title": "JsonForge"
  },

  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },

  "permissions": [
    "storage",
    "clipboardWrite"
  ],

  "host_permissions": [],

  "background": {
    "service_worker": "background.js"
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}